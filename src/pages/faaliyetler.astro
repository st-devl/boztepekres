---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site.config";
import { hero, faaliyetler, bilgiKartlari, cta, modal } from "../data/faaliyetler";
---

<BaseLayout
  title="Trabzon Anaokulu Etkinlikleri | Okul Öncesi Faaliyetler & Atölyeler"
  description={hero.paragraf}
>
  <!-- Modal -->
  <div class="fixed inset-0 z-[100] hidden items-center justify-center px-4 bg-on-surface/40 backdrop-blur-sm transition-opacity duration-300" id="enrollModal">
    <div class="bg-surface w-full max-w-[512px] rounded-[32px] overflow-hidden tonal-shadow relative animate-in fade-in zoom-in duration-300">
      <div class="bg-primary p-lg text-white relative">
        <button class="absolute top-4 right-4 text-white hover:rotate-90 transition-transform" onclick="toggleModal()">
          <span class="material-symbols-outlined">close</span>
        </button>
        <h3 class="font-headline-lg text-headline-lg mb-xs">{modal.baslik}</h3>
        <p class="font-body-md opacity-90">{modal.altBaslik}</p>
      </div>
      <form class="p-lg space-y-md" id="enrollForm">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
          <div class="flex flex-col gap-xs">
            <label class="font-label-md text-label-md text-on-surface-variant ml-2">{modal.alanlar.veliAd}</label>
            <input class="w-full bg-surface-container-low border border-outline-variant rounded-full px-md py-sm focus:border-primary focus:ring-0 font-body-md" placeholder="Adınız Soyadınız" required type="text" />
          </div>
          <div class="flex flex-col gap-xs">
            <label class="font-label-md text-label-md text-on-surface-variant ml-2">{modal.alanlar.ogrenciAd}</label>
            <input class="w-full bg-surface-container-low border border-outline-variant rounded-full px-md py-sm focus:border-primary focus:ring-0 font-body-md" placeholder="Öğrenci Adı" required type="text" />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
          <div class="flex flex-col gap-xs">
            <label class="font-label-md text-label-md text-on-surface-variant ml-2">{modal.alanlar.yasGrubu}</label>
            <select class="w-full bg-surface-container-low border border-outline-variant rounded-full px-md py-sm focus:border-primary focus:ring-0 font-body-md appearance-none">
              {modal.yasSecenekleri.map((y) => <option>{y}</option>)}
            </select>
          </div>
          <div class="flex flex-col gap-xs">
            <label class="font-label-md text-label-md text-on-surface-variant ml-2">{modal.alanlar.telefon}</label>
            <input class="w-full bg-surface-container-low border border-outline-variant rounded-full px-md py-sm focus:border-primary focus:ring-0 font-body-md" placeholder="05XX XXX XX XX" required type="tel" />
          </div>
        </div>
        <div class="flex flex-col gap-xs">
          <label class="font-label-md text-label-md text-on-surface-variant ml-2">{modal.alanlar.mesaj}</label>
          <textarea class="w-full bg-surface-container-low border border-outline-variant rounded-[24px] px-md py-sm focus:border-primary focus:ring-0 font-body-md" placeholder="Sormak istediklerinizi buraya yazabilirsiniz..." rows="3"></textarea>
        </div>
        <button class="w-full bg-primary text-on-primary py-md rounded-full font-button text-button shadow-md hover:bg-on-primary-container transition-all active:scale-95" type="submit">{modal.buton}</button>
      </form>
    </div>
  </div>

  <main class="pt-[100px] pb-xl overflow-hidden relative">
    <div class="blob-bg top-20 -left-20 w-[400px] h-[400px] bg-primary-container rounded-full"></div>
    <div class="blob-bg top-[40%] -right-20 w-[500px] h-[500px] bg-tertiary-container rounded-full"></div>

    <!-- Hero -->
    <section class="max-w-container-max mx-auto px-gutter mb-xl text-center">
      <h1 class="font-headline-xl text-primary mb-md md:text-[40px] text-[28px]">{hero.baslik}</h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-[42rem] mx-auto mb-lg">
        {hero.paragraf}
      </p>
      <div class="flex flex-wrap justify-center gap-sm">
        {hero.etiketler.map((e) => (
          <span class:list={["px-md py-xs rounded-full font-label-md text-label-md", e.renk]}>{e.metin}</span>
        ))}
      </div>
    </section>

    <!-- Bento Grid -->
    <section class="max-w-container-max mx-auto px-gutter mb-xl">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-md">
        {faaliyetler.map((f) => (
          <div class:list={["group relative overflow-hidden rounded-[24px] bg-white tonal-shadow", f.boyut, f.yukseklik]}>
            <img
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              alt={f.gorselAlt}
              src={f.gorsel}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-on-surface/80 via-transparent to-transparent flex flex-col justify-end p-lg">
              <div class="flex items-center gap-sm mb-xs">
                <span class:list={["material-symbols-outlined", f.ikonRenk]} style="font-variation-settings: 'FILL' 1;">{f.ikon}</span>
                <h3 class="font-headline-md text-headline-md text-white">{f.baslik}</h3>
              </div>
              {f.aciklama && <p class="text-white/90 font-body-md">{f.aciklama}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Bilgi Kartları -->
    <section class="max-w-container-max mx-auto px-gutter mb-xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-lg">
        {bilgiKartlari.map((k) => (
          <div class:list={["bg-white p-lg rounded-[24px] tonal-shadow", k.sinif]}>
            <div class:list={["w-12 h-12 rounded-xl flex items-center justify-center mb-md", k.renkBg]}>
              <span class:list={["material-symbols-outlined", k.renkText]}>{k.ikon}</span>
            </div>
            <h4 class="font-headline-md text-headline-md mb-sm">{k.baslik}</h4>
            <p class="font-body-md text-on-surface-variant">{k.aciklama}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-container-max mx-auto px-gutter mb-xl">
      <div class="bg-primary-container rounded-[32px] p-xl text-center relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-white/20 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <h2 class="font-headline-xl text-on-primary-container mb-md md:text-[32px] text-[24px]">{cta.baslik}</h2>
        <p class="font-body-lg text-body-lg text-on-primary-container/80 mb-lg max-w-[36rem] mx-auto">
          {cta.paragraf}
        </p>
        <button class="bg-primary text-on-primary px-xl py-md rounded-full text-button font-button shadow-lg hover:bg-on-primary-container transition-all active:scale-95" onclick="toggleModal()">{cta.buton}</button>
      </div>
    </section>
  </main>

  <!-- Mobil Alt Nav -->
  <nav class="fixed bottom-0 left-0 w-full flex justify-around items-center h-20 px-4 pb-2 bg-surface shadow-[0_-4px_10px_rgba(0,0,0,0.05)] md:hidden z-50">
    <a class="flex flex-col items-center justify-center text-on-surface-variant transition-transform active:scale-90" href={`tel:${site.phone.replace(/\s/g, "")}`}>
      <span class="material-symbols-outlined">call</span>
      <span class="font-label-md text-label-md">Ara</span>
    </a>
    <a class="flex flex-col items-center justify-center bg-primary-container text-on-primary-container rounded-full px-4 py-1 transition-transform active:scale-90" href={`https://wa.me/${site.whatsapp.replace(/\D/g, "")}`} target="_blank" rel="noopener">
      <span class="material-symbols-outlined">chat</span>
      <span class="font-label-md text-label-md">WhatsApp</span>
    </a>
    <a class="flex flex-col items-center justify-center text-on-surface-variant transition-transform active:scale-90" href="/">
      <span class="material-symbols-outlined">location_on</span>
      <span class="font-label-md text-label-md">Konum</span>
    </a>
    <button class="flex flex-col items-center justify-center text-primary transition-transform active:scale-90" onclick="toggleModal()">
      <span class="material-symbols-outlined">edit_note</span>
      <span class="font-label-md text-label-md">Ön Kayıt</span>
    </button>
  </nav>
</BaseLayout>

<script>
  function toggleModal() {
    const modal = document.getElementById('enrollModal');
    if (!modal) return;
    modal.classList.toggle('hidden');
    modal.classList.toggle('flex');
    document.body.style.overflow = !modal.classList.contains('hidden') ? 'hidden' : 'auto';
  }
  (window as any).toggleModal = toggleModal;

  document.getElementById('enrollForm')?.addEventListener('submit', function(e) {
    e.preventDefault();
    alert('Ön kayıt talebiniz başarıyla alındı. Teşekkür ederiz!');
    toggleModal();
  });

  window.onclick = function(event) {
    const modal = document.getElementById('enrollModal');
    if (modal && event.target === modal) toggleModal();
  };
</script>
