---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site.config";

const values = [
  { icon: "💖", title: "Sevgi", text: "Her çocuk koşulsuz sevgiyle karşılanır. Güvenli bağlanma temelimizdir." },
  { icon: "🌍", title: "Saygı", text: "Çocuğun bireyselliğine, ailesine ve doğaya saygı duyarız." },
  { icon: "🔍", title: "Merak", text: "Çocukların doğal merakını canlı tutarak öğrenme aşkı oluştururuz." },
  { icon: "🤝", title: "İş Birliği", text: "Aile-okul iş birliği gelişimin temel yapı taşıdır." },
  { icon: "🎯", title: "Gelişim", text: "Her çocuğun kendi temposunda ilerlemesini destekleriz." },
  { icon: "🌿", title: "Doğa", text: "Trabzon'un eşsiz doğasını eğitim ortamına dahil ederiz." },
];

const team = [
  { name: "Ayşegül Demir", role: "Kurucu / Pedagog", bio: "20 yıllık okul öncesi eğitim deneyimi, Karadeniz Teknik Üniversitesi mezunu.", emoji: "👩‍🎓" },
  { name: "Selin Yıldız", role: "Müdür Yardımcısı", bio: "Çocuk gelişimi uzmanı, Reggio Emilia sertifikalı eğitmen.", emoji: "👩‍🏫" },
  { name: "Burcu Aksoy", role: "Anaokulu Öğretmeni", bio: "Montessori AMI sertifikalı, 8 yıllık deneyim.", emoji: "🧑‍🏫" },
  { name: "Elif Kaya", role: "Anaokulu Öğretmeni", bio: "Okul öncesi öğretmenliği mezunu, drama ve müzik eğitmeni.", emoji: "👩" },
  { name: "Merve Şahin", role: "Bebek Bakım Uzmanı", bio: "Pediatrik bakım sertifikalı, 0-2 yaş uzmanı.", emoji: "🤱" },
  { name: "Deniz Çelik", role: "İngilizce Eğitmeni", bio: "TEFL sertifikalı, çocuklara özel İngilizce metodları.", emoji: "🗣️" },
];

const ld = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: "Hakkımızda - Boztepe Kreş",
    url: `${site.url}/hakkimizda`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
      { "@type": "ListItem", position: 2, name: "Hakkımızda", item: `${site.url}/hakkimizda` },
    ],
  },
];
---

<BaseLayout
  title="Hakkımızda - Trabzon Boztepe Anaokulu"
  description="Boztepe Kreş ve Anaokulu: 12 yıldır Trabzon'da çocukların gelişimi için çalışan, deneyimli kadrosu ve modern eğitim yaklaşımıyla fark yaratan kurumumuzu tanıyın."
  keywords={["trabzon anaokulu hakkında", "boztepe kreş ekip", "trabzon eğitim kadrosu"]}
  jsonLd={ld}
>
  <!-- Header -->
  <section class="relative overflow-hidden">
    <div class="blob bg-brand-200 w-[400px] h-[400px] -top-32 -right-32"></div>
    <div class="container-x relative z-10 pt-16 pb-12 md:pt-24 md:pb-16">
      <nav aria-label="Breadcrumb" class="text-sm text-ink-500">
        <ol class="flex gap-2 items-center">
          <li><a href="/" class="hover:text-brand-600">Ana Sayfa</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-ink-900 font-medium">Hakkımızda</li>
        </ol>
      </nav>
      <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl mt-5 max-w-3xl leading-tight">
        12 yıldır Trabzon'da <span class="text-brand-600">çocukların yanında</span>
      </h1>
      <p class="mt-5 text-lg text-ink-700 max-w-2xl">
        Boztepe Kreş ve Anaokulu, 2013 yılından bu yana Trabzon'un Boztepe semtinde, çocukların sevgiyle, güvenle ve oyunla büyüdüğü bir yuva olarak hizmet veriyor.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="section">
    <div class="container-x grid lg:grid-cols-5 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-2">
        <div class="aspect-square rounded-3xl bg-gradient-to-br from-brand-100 via-pink-soft to-sky-soft p-1">
          <div class="w-full h-full rounded-[1.4rem] bg-white grid place-items-center text-7xl" aria-hidden="true">
            🏫
          </div>
        </div>
      </div>
      <div class="lg:col-span-3">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider">Hikayemiz</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl mt-2">Bir öğretmenin hayalinden Trabzon'un sevilen kreşine</h2>
        <div class="mt-6 space-y-4 text-ink-700 leading-relaxed">
          <p>
            <strong class="text-ink-900">Boztepe Kreş</strong>, kurucumuz Ayşegül Demir'in 2013 yılında "her çocuğun gelişimine değer veren bir okul" hayaliyle yola çıktı. Bugün 400'den fazla mezunumuzla Trabzon'un en köklü özel anaokullarından biriyiz.
          </p>
          <p>
            Reggio Emilia, Montessori ve MEB müfredatını harmanlayan eğitim modelimiz, her çocuğu kendi potansiyeliyle değerlendirir. Sınıflarımız küçük gruplardan oluşur ki her çocuk hak ettiği bireysel ilgiyi görsün.
          </p>
          <p>
            <strong class="text-ink-900">Misyonumuz:</strong> Çocukların özgüvenli, meraklı, sosyal ve dünyaya değer katacak bireyler olarak yetişmesini desteklemek.
          </p>
          <p>
            <strong class="text-ink-900">Vizyonumuz:</strong> Trabzon ve Karadeniz Bölgesi'nin en güvenilir, en yenilikçi okul öncesi eğitim kurumu olmak.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section bg-gradient-to-b from-transparent via-orange-50/40 to-transparent">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider">Değerlerimiz</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl mt-2">Bizi biz yapan ilkelerimiz</h2>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {values.map((v) => (
          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-brand-50 grid place-items-center text-2xl" aria-hidden="true">{v.icon}</div>
            <h3 class="font-display font-bold text-lg mt-4">{v.title}</h3>
            <p class="mt-2 text-sm text-ink-700 leading-relaxed">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider">Ekibimiz</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl mt-2">Sevgiyle öğreten, bilimle yetiştiren kadromuz</h2>
        <p class="mt-3 text-ink-700">Tüm öğretmenlerimiz okul öncesi eğitim formasyonuna sahip, sürekli eğitimlerle kendini geliştirir.</p>
      </div>

      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {team.map((m) => (
          <article class="card text-center">
            <div class="w-24 h-24 mx-auto rounded-full bg-gradient-to-br from-brand-100 to-pink-soft grid place-items-center text-5xl" aria-hidden="true">
              {m.emoji}
            </div>
            <h3 class="font-display font-bold text-lg mt-5">{m.name}</h3>
            <p class="text-brand-600 text-sm font-semibold">{m.role}</p>
            <p class="mt-3 text-sm text-ink-700 leading-relaxed">{m.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container-x">
      <div class="card text-center max-w-3xl mx-auto bg-gradient-to-br from-brand-50 to-pink-soft border-brand-100">
        <h2 class="font-display font-bold text-2xl md:text-3xl">Kurumumuzu yakından tanımak ister misiniz?</h2>
        <p class="mt-3 text-ink-700">30 dakikalık ücretsiz tanışma turumuza katılın, ekibimizle tanışın.</p>
        <a href="/iletisim" class="btn btn-primary mt-6">Randevu Al →</a>
      </div>
    </div>
  </section>
</BaseLayout>
