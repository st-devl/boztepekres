---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../site.config";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const ld = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Boztepe Kreş Blog",
  url: `${site.url}/blog`,
  description: "Trabzon Boztepe Kreş ve Anaokulu blogu: çocuk gelişimi, anaokulu seçimi, Montessori, Reggio Emilia ve aile rehberi.",
};

const fmt = (d: Date) => d.toLocaleDateString("tr-TR", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout
  title="Blog - Trabzon Anaokulu ve Çocuk Gelişimi"
  description="Çocuk gelişimi, anaokulu seçimi, Montessori, Reggio Emilia ve aile rehberi yazıları. Trabzon Boztepe Kreş uzmanlarından."
  keywords={["çocuk gelişimi blog", "trabzon anaokulu blog", "anaokulu rehberi", "aile blog"]}
  jsonLd={ld}
>
  <section class="relative overflow-hidden">
    <div class="blob bg-yellow-soft w-[400px] h-[400px] -top-32 -right-32"></div>
    <div class="container-x relative z-10 pt-16 pb-12 md:pt-24 md:pb-16">
      <nav aria-label="Breadcrumb" class="text-sm text-ink-500">
        <ol class="flex gap-2 items-center">
          <li><a href="/" class="hover:text-brand-600">Ana Sayfa</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-ink-900 font-medium">Blog</li>
        </ol>
      </nav>
      <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl mt-5 max-w-3xl leading-tight">
        Velilere <span class="text-brand-600">rehber</span> yazılarımız
      </h1>
      <p class="mt-5 text-lg text-ink-700 max-w-2xl">
        Çocuk gelişimi, anaokulu seçimi ve eğitim yaklaşımlarımız hakkında uzman yazılarımız.
      </p>
    </div>
  </section>

  <section class="container-x pb-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map((p) => (
        <article class="card group !p-0 overflow-hidden flex flex-col">
          <a href={`/blog/${p.id}`} class="block">
            <div class="aspect-[16/10] bg-gradient-to-br from-brand-100 via-pink-soft to-sky-soft grid place-items-center text-7xl group-hover:scale-105 transition-transform" aria-hidden="true">
              {p.data.coverEmoji}
            </div>
          </a>
          <div class="p-6 flex flex-col flex-1">
            <div class="flex flex-wrap gap-2 mb-3">
              {p.data.tags.slice(0, 2).map((t) => (
                <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-brand-50 text-brand-700">{t}</span>
              ))}
            </div>
            <h2 class="font-display font-bold text-lg leading-tight">
              <a href={`/blog/${p.id}`} class="hover:text-brand-600">{p.data.title}</a>
            </h2>
            <p class="mt-2 text-sm text-ink-700 leading-relaxed line-clamp-3">{p.data.description}</p>
            <div class="mt-5 pt-5 border-t border-orange-100 flex items-center justify-between text-xs text-ink-500">
              <time datetime={p.data.publishDate.toISOString()}>{fmt(p.data.publishDate)}</time>
              <span>{p.data.author}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
