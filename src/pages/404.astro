---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Sayfa Bulunamadı" noindex={true}>
  <section class="container-x py-24 md:py-32 text-center">
    <div class="text-7xl mb-6" aria-hidden="true">🧸</div>
    <p class="text-sm font-bold uppercase tracking-wider text-brand-600">404</p>
    <h1 class="font-display font-bold text-4xl md:text-5xl mt-3">Aradığınız sayfa kayboldu</h1>
    <p class="mt-4 text-ink-700 max-w-md mx-auto">Sayfayı bulamadık. Ana sayfaya dönerek devam edebilirsiniz.</p>
    <a href="/" class="btn btn-primary mt-8">Ana Sayfaya Dön</a>
  </section>
</BaseLayout>
